{
  "Routes": [
    //Catalog API
    {
      "DownstreamPathTemplate": "/api/v1/Catalog",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "catalog.api",
          "Port": 8000
        }
      ],
      //"AuthenticationOptions": {
      //  "AuthenticationProviderKey": "Bearer"
      //},
      "UpstreamPathTemplate": "/Catalog",
      "UpstreamHttpMethod": [ "GET", "POST", "PUT" ],
      "FileCacheOptions": { "TtlSeconds": 30 }
    },
    {
      "DownstreamPathTemplate": "/api/v1/Catalog/GetProductById/{id}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "catalog.api",
          "Port": 8000
        }
      ],
      //"AuthenticationOptions": {
      //  "AuthenticationProviderKey": "Bearer"
      //},
      "UpstreamPathTemplate": "/Catalog/GetProductById/{id}",
      "UpstreamHttpMethod": [ "GET", "DELETE" ]
    },
    {
      "DownstreamPathTemplate": "/api/v1/Catalog/GetAllProducts",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "catalog.api",
          "Port": 8000
        }
      ],
      //"AuthenticationOptions": {
      //  "AuthenticationProviderKey": "Bearer"
      //},
      "UpstreamPathTemplate": "/Catalog/GetAllProducts",
      "UpstreamHttpMethod": [ "GET", "DELETE" ]
    },
    {
      "DownstreamPathTemplate": "/api/v1/Catalog/GetAllBrands",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "catalog.api",
          "Port": 8000
        }
      ],
      //"AuthenticationOptions": {
      //  "AuthenticationProviderKey": "Bearer"
      //},
      "UpstreamPathTemplate": "/Catalog/GetAllBrands",
      "UpstreamHttpMethod": [ "GET", "DELETE" ]
    },
    {
      "DownstreamPathTemplate": "/api/v1/Catalog/GetAllTypes",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "catalog.api",
          "Port": 8000
        }
      ],
      //"AuthenticationOptions": {
      //  "AuthenticationProviderKey": "Bearer"
      //},
      "UpstreamPathTemplate": "/Catalog/GetAllTypes",
      "UpstreamHttpMethod": [ "GET", "DELETE" ]
    },
    {
      "DownstreamPathTemplate": "/api/v1/Catalog/GetProductsByBrandName/{brand}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "catalog.api",
          "Port": 8000
        }
      ],
      //"AuthenticationOptions": {
      //  "AuthenticationProviderKey": "Bearer"
      //},
      "UpstreamPathTemplate": "/Catalog/GetProductsByBrandName/{brand}",
      "UpstreamHttpMethod": [ "GET" ]
    },
    //Basket API
    {
      "DownstreamPathTemplate": "/api/v1/BasketApi/GetBasket/{userName}",
      "DownstreamScheme": "http",
      //"AuthenticationOptions": {
      //  "AuthenticationProviderKey": "Bearer"
      //},
      "DownstreamHostAndPorts": [
        {
          "Host": "host.docker.internal",
          "Port": 8001
        }
      ],
      "UpstreamPathTemplate": "/Basket/GetBasket/{userName}",
      "UpstreamHttpMethod": [ "GET" ]
    },
    {
      "DownstreamPathTemplate": "/api/v1/BasketApi/DeleteBasket/{userName}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "host.docker.internal",
          "Port": 8001
        }
      ],
      "UpstreamPathTemplate": "/Basket/DeleteBasket/{userName}",
      "UpstreamHttpMethod": [ "DELETE" ]
    },
    {
      "DownstreamPathTemplate": "/api/v1/BasketApi/CreateBasket",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "host.docker.internal",
          "Port": 8001
        }
      ],
      "UpstreamPathTemplate": "/Basket/CreateBasket",
      "UpstreamHttpMethod": [ "POST" ]
    },
    {
      "DownstreamPathTemplate": "/api/v1/BasketApi/Checkout",
      "DownstreamScheme": "http",
      //"AuthenticationOptions": {
      //  "AuthenticationProviderKey": "Bearer"
      //},
      "DownstreamHostAndPorts": [
        {
          "Host": "host.docker.internal",
          "Port": 8001
        }
      ],
      "UpstreamPathTemplate": "/Basket/Checkout",
      "UpstreamHttpMethod": [ "POST" ],
      "RateLimitOptions": {
        "ClientWhitelist": [],
        "EnableRateLimiting": true,
        "Period": "3s",
        "PeriodTimespan": 1,
        "Limit": 1
      }
    },
    {
      "DownstreamPathTemplate": "/api/v2/BasketApi/Checkout",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "host.docker.internal",
          "Port": 8001
        }
      ],
      "UpstreamPathTemplate": "/Basket/CheckoutV2",
      "UpstreamHttpMethod": [ "POST" ],
      "RateLimitOptions": {
        "ClientWhitelist": [],
        "EnableRateLimiting": true,
        "Period": "3s",
        "PeriodTimespan": 1,
        "Limit": 1
      }
    },
    //Discount API
    {
      "DownstreamPathTemplate": "/api/v1/Discount/{productName}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "discount.api",
          "Port": 8002
        }
      ],
      "UpstreamPathTemplate": "/Discount/{productName}",
      "UpstreamHttpMethod": [ "GET", "DELETE" ]
    },
    {
      "DownstreamPathTemplate": "/api/v1/Discount",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "discount.api",
          "Port": 8002
        }
      ],
      "UpstreamPathTemplate": "/Discount",
      "UpstreamHttpMethod": [ "PUT", "POST" ]
    },
    //Order API
    {
      "DownstreamPathTemplate": "/api/v1/Order/{userName}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "host.docker.internal",
          "Port": 8003
        }
      ],
      "UpstreamPathTemplate": "/Order/{userName}",
      "UpstreamHttpMethod": [ "GET" ]
    }
  ],
  "GlobalConfiguration": {
    "BaseUrl": "http://localhost:8010"
  }
}